{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/sw.js",
      "/service-worker.js",
      "/manifest.json",
      "/manifest.webmanifest",
      "/*.png",
      "/*.ico",
      "/*.svg",
      "/*.webmanifest"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".json": "application/json",
    ".webmanifest": "application/manifest+json"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}